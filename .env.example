# =============================================================
#  Postieur — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# =============================================================

# ── Clerk Authentication ───────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Clerk webhook secret — from Clerk dashboard > Webhooks
CLERK_WEBHOOK_SECRET=whsec_...

# ── App ────────────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Used for OAuth callbacks.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Database (Neon / PostgreSQL) ───────────────────────────────
# Use the pooled connection for most queries
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Use the direct (non-pooled) connection for Prisma migrations
DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Vercel Blob Storage ────────────────────────────────────────
# From Vercel dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Cron Security ─────────────────────────────────────────────
# Random secret string — must match vercel.json cron auth header
CRON_SECRET=your-random-cron-secret-here

# ── Webhooks ───────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret
INBOX_WEBHOOK_SECRET=your-inbox-webhook-secret

# ── X (Twitter) OAuth 2.0 ─────────────────────────────────────
# https://developer.twitter.com/en/portal/projects
# Required scopes: tweet.read tweet.write users.read offline.access


TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── LinkedIn OAuth ─────────────────────────────────────────────
# https://www.linkedin.com/developers/apps
# Required scopes: openid profile email w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Meta (Facebook + Instagram) OAuth ─────────────────────────
# https://developers.facebook.com/apps/
# Required scopes: pages_manage_posts pages_read_engagement instagram_content_publish
META_APP_ID=
META_APP_SECRET=

# ── Reddit OAuth ───────────────────────────────────────────────
# https://www.reddit.com/prefs/apps
# Required scopes: identity submit read
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── YouTube / Google OAuth ────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Required scopes: youtube.upload youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Discord OAuth ──────────────────────────────────────────────
# https://discord.com/developers/applications
# Required scopes: webhook.incoming identify
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Threads OAuth ─────────────────────────────────────────────
# https://developers.facebook.com/docs/threads
# Required scopes: threads_basic threads_content_publish
THREADS_APP_ID=
THREADS_APP_SECRET=

# ── Bluesky (App Password — no OAuth app needed) ──────────────
# Users connect via handle + app password in the Channels UI.
# No server-side credentials required.

# ── Telegram (Bot Token) ──────────────────────────────────────
# Users connect via @BotFather token in the Channels UI.
# No server-side credentials required.

# ── TikTok OAuth ──────────────────────────────────────────────
# https://developers.tiktok.com/
# Required scopes: user.info.basic video.publish video.upload
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Pinterest OAuth ────────────────────────────────────────────
# https://developers.pinterest.com/apps/
# Required scopes: boards:read pins:read pins:write
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# ── Resend (email notifications) ──────────────────────────────
# https://resend.com/
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@your-domain.com
