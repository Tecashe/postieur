// Prisma 7 schema — connection URL is in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  PENDING_APPROVAL
}

enum PostType {
  POST
  THREAD
  CAROUSEL
  REEL
  STORY
  ARTICLE
}

enum MediaType {
  IMAGE
  VIDEO
  GIF
  DOCUMENT
}

enum Plan {
  FREE
  PRO
  AGENCY
}

// --- Workspace ---

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  clerkOrgId  String   @unique
  plan        Plan     @default(FREE)
  logoUrl     String?
  description String?
  // Approval workflow
  requireApproval  Boolean @default(false)
  // Display preferences
  timezone         String  @default("UTC")
  dateFormat       String  @default("MMM D, YYYY")
  weekStartsOn     Int     @default(1) // 0 = Sunday, 1 = Monday
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channels        Channel[]
  posts           Post[]
  mediaItems      MediaItem[]
  aiUsage         AIUsageLog[]
  apiKeys         ApiKey[]
  webhooks        WebhookEndpoint[]
  rssFeeds        RssFeed[]
  autoActions     AutoAction[]
  linkInBioPages  LinkInBioPage[]
  templates       Template[]
  campaigns       Campaign[]
  inboxMessages   InboxMessage[]
  queueSlots      QueueSlot[]
  signatures      Signature[]
  notifPrefs      NotificationPreference[]
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@map("workspaces")
}

// --- Channel ---

model Channel {
  id           String    @id @default(cuid())
  workspaceId  String
  platform     String
  handle       String
  displayName  String?
  avatarUrl    String?
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)
  followers    Int       @default(0)
  config       Json?     @default("{}") // platform-specific data: pageId, igUserId, personUrn, webhookUrl, did, chatId, etc.
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  postChannels PostChannel[]

  @@unique([workspaceId, platform, handle])
  @@map("channels")
}

// --- Post ---

model Post {
  id                    String     @id @default(cuid())
  workspaceId           String
  content               String
  type                  PostType   @default(POST)
  status                PostStatus @default(DRAFT)
  scheduledAt           DateTime?
  publishedAt           DateTime?
  failedAt              DateTime?
  failReason            String?
  mediaUrls             String[]   @default([])
  threadPosts           String[]   @default([])
  labels                String[]   @default([])
  campaignId            String?
  crossPostDelayMinutes Int        @default(0)
  createdById           String?
  recycleEnabled        Boolean    @default(false)
  recycleIntervalDays   Int?
  recycleNextAt         DateTime?
  recycleSourceId       String?
  // Approval workflow
  approvedById          String?
  approvedAt            DateTime?
  approvalNote          String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  workspace  Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channels   PostChannel[]
  analytics  PostAnalytics?

  @@index([workspaceId, status])
  @@index([workspaceId, scheduledAt])
  @@map("posts")
}

// --- PostChannel ---

model PostChannel {
  id             String     @id @default(cuid())
  postId         String
  channelId      String
  status         PostStatus @default(SCHEDULED)
  platformPostId String?
  publishedAt    DateTime?
  failReason     String?
  config         Json?      @default("{}")

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([postId, channelId])
  @@map("post_channels")
}

// --- PostAnalytics ---

model PostAnalytics {
  id          String   @id @default(cuid())
  postId      String   @unique
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  saves       Int      @default(0)
  reach       Int      @default(0)
  syncedAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_analytics")
}

// --- MediaItem ---

model MediaItem {
  id           String    @id @default(cuid())
  workspaceId  String
  url          String
  filename     String
  mimeType     String
  sizeBytes    Int
  type         MediaType
  width        Int?
  height       Int?
  duration     Float?
  altText      String?
  uploadedById String?
  createdAt    DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("media_items")
}

// --- AIUsageLog ---

model AIUsageLog {
  id               String   @id @default(cuid())
  workspaceId      String
  userId           String?
  feature          String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  cost             Float    @default(0)
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("ai_usage_logs")
}

// --- ApiKey ---

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

model ApiKey {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String       @unique
  prefix      String
  scopes      String[]     @default([])
  status      ApiKeyStatus @default(ACTIVE)
  lastUsedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("api_keys")
}

// --- WebhookEndpoint ---

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

model WebhookEndpoint {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  url             String
  events          String[] @default([])
  secret          String
  isActive        Boolean  @default(true)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([workspaceId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String                @id @default(cuid())
  webhookId    String
  event        String
  payload      Json
  responseCode Int?
  status       WebhookDeliveryStatus @default(PENDING)
  error        String?
  createdAt    DateTime              @default(now())

  webhook WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

// --- RssFeed ---

model RssFeed {
  id                     String   @id @default(cuid())
  workspaceId            String
  name                   String
  url                    String
  isEnabled              Boolean  @default(true)
  checkIntervalHours     Int      @default(6)
  autoPublishChannelIds  String[] @default([])
  lastFetchedAt          DateTime?
  lastError              String?
  postsCreated           Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("rss_feeds")
}

// --- AutoAction ---

enum AutoActionTrigger {
  POST_PUBLISHED
  FOLLOWER_MILESTONE
  SCHEDULED_TIME
  RSS_ITEM_CREATED
  NEW_COMMENT
}

enum AutoActionType {
  NOTIFY_WEBHOOK
  CREATE_POST
  SEND_EMAIL
  AUTO_LIKE
  AUTO_COMMENT
}

model AutoAction {
  id           String            @id @default(cuid())
  workspaceId  String
  name         String
  isEnabled    Boolean           @default(true)
  triggerType  AutoActionTrigger
  triggerValue String?
  actionType   AutoActionType
  channelIds   String[]          @default([])
  config       Json              @default("{}")
  lastRunAt    DateTime?
  runCount     Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("auto_actions")
}

// --- LinkInBioPage ---

model LinkInBioPage {
  id          String   @id @default(cuid())
  workspaceId String
  slug        String   @unique
  title       String
  bio         String?
  avatarUrl   String?
  pageViews   Int      @default(0)
  isPublished Boolean  @default(true)
  themeColor  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     LinkInBioLink[]

  @@index([workspaceId])
  @@map("link_in_bio_pages")
}

model LinkInBioLink {
  id        String  @id @default(cuid())
  pageId    String
  title     String
  url       String
  platform  String?
  clicks    Int     @default(0)
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  page LinkInBioPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("link_in_bio_links")
}

// --- Template ---

model Template {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  category    String   @default("general")
  content     String
  platforms   String[] @default([])
  tags        String[] @default([])
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("templates")
}

// --- Campaign ---

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Campaign {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  platforms   String[]       @default([])
  color       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("campaigns")
}

// --- InboxMessage ---

enum InboxMessageType {
  COMMENT
  MENTION
  DM
  REPLY
}

enum InboxSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model InboxMessage {
  id          String           @id @default(cuid())
  workspaceId String
  channelId   String?
  platform    String
  type        InboxMessageType @default(COMMENT)
  authorId    String?
  authorName  String
  authorAvatar String?
  content     String
  postContent String?
  sentiment   InboxSentiment   @default(NEUTRAL)
  isRead      Boolean          @default(false)
  isArchived  Boolean          @default(false)
  externalId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform, externalId])
  @@index([workspaceId, isRead])
  @@map("inbox_messages")
}

// --- QueueSlot ---

model QueueSlot {
  id          String   @id @default(cuid())
  workspaceId String
  dayOfWeek   Int
  hour        Int
  minute      Int      @default(0)
  platforms   String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, dayOfWeek, hour, minute])
  @@index([workspaceId])
  @@map("queue_slots")
}

// --- Signature ---

model Signature {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?  // null = workspace-wide default
  name        String
  content     String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("signatures")
}

// --- NotificationPreference ---

model NotificationPreference {
  id           String  @id @default(cuid())
  workspaceId  String
  userId       String
  type         String  // 'POST_PUBLISHED' | 'POST_FAILED' | 'NEW_COMMENT' | 'NEW_MENTION' | 'WEEKLY_REPORT' | 'TEAM_ACTIVITY' | 'QUEUE_EMPTY'
  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId, type])
  @@index([workspaceId, userId])
  @@map("notification_preferences")
}

// --- Notification ---

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String   // target user
  type        String   // POST_PUBLISHED | POST_FAILED | NEW_COMMENT | NEW_MENTION | TEAM_ACTIVITY | QUEUE_EMPTY
  title       String
  body        String?
  entityId    String?  // postId, channelId, etc.
  entityType  String?  // 'post' | 'channel' | etc.
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, isRead])
  @@index([workspaceId, createdAt])
  @@map("notifications")
}

// --- AuditLog ---

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  action      String   // 'post.created' | 'post.deleted' | 'member.invited' | 'channel.connected' | etc.
  entityId    String?
  entityType  String?
  meta        Json?    @default("{}")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}